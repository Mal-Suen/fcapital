# fcapital 环境变量配置示例
# 复制此文件为 .env 并填入您的实际密钥
# cp .env.example .env

# =============================================================================
# AI Provider 配置
# =============================================================================
# 支持三种 AI Provider: openai, deepseek, ollama
# 使用 --provider 参数选择: fcapital ai-scan -t example.com --provider deepseek

# DeepSeek 配置（推荐，性价比高）
# 获取密钥: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI 配置
# 获取密钥: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama 配置（本地运行，无需密钥）
# 安装: https://ollama.ai/
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# =============================================================================
# 通用 AI 配置（可选）
# =============================================================================
# 如果只使用单一 Provider，可以设置通用密钥
# AI_API_KEY=your_api_key_here
# AI_PROVIDER=deepseek

# =============================================================================
# 工具配置（可选）
# =============================================================================
# 自定义工具路径（如果工具不在标准路径）
# NMAP_PATH=/usr/bin/nmap
# GOBIN_PATH=/home/user/go/bin

# =============================================================================
# 输出配置（可选）
# =============================================================================
# 输出目录
# OUTPUT_DIR=./output
# 报告格式
# REPORT_FORMAT=json

# =============================================================================
# 调试配置（可选）
# =============================================================================
# 启用详细日志
# VERBOSE=true
# 日志级别
# LOG_LEVEL=debug